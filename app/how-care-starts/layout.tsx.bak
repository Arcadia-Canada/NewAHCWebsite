"use client"

import Link from "next/link"
import { colors, fonts, phone, trustItems } from "@/components/arcadia-colors"

const steps = [
  { num: 1, title: "Book a Free Consultation", description: "A no-obligation call where we listen to your situation and begin to understand what your family needs.", href: "/contact/", icon: "📞" },
  { num: 2, title: "Care Assessment", description: "An in-home visit to understand your loved one's daily routines, medical needs, and personal preferences.", href: "/how-care-starts/care-assessment/", icon: "📋" },
  { num: 3, title: "Matching Caregivers", description: "We carefully match your family with a caregiver suited to your loved one's personality, language, and care requirements.", href: "/how-care-starts/matching-caregivers/", icon: "🤝" },
  { num: 4, title: "First Week of Care", description: "Care begins with close monitoring and daily check-ins to ensure everything is working well for your family.", href: "/how-care-starts/first-week-of-care/", icon: "📅" },
  { num: 5, title: "Pricing and Funding", description: "We help you navigate insurance coverage, publicly funded options, and private pay — clearly and honestly.", href: "/how-care-starts/pricing-and-funding/", icon: "💰" },
  { num: 6, title: "Referral Process", description: "For discharge planners and health professionals: a streamlined pathway to get your patient the right support fast.", href: "/how-care-starts/referral-process/", icon: "📨" },
  { num: 7, title: "Ongoing Support", description: "We stay in touch as care continues — reviewing the care plan, adjusting as needs change, and making sure your family has the support that fits.", href: "/how-care-starts/ongoing-support/", icon: "🌱" },
]

export default function HowCareStartsHubPage() {
  return (
    <main style={{ fontFamily: fonts.body, color: colors.text }}>

      {/* Hero */}
      <section style={{ background: colors.primary, padding: "96px 24px 80px", textAlign: "center" }}>
        <div style={{ maxWidth: 720, margin: "0 auto" }}>
          <p style={{ fontSize: 12, fontWeight: 700, letterSpacing: "0.1em", textTransform: "uppercase", color: colors.accent, marginBottom: 16 }}>
            How Care Starts
          </p>
          <h1 style={{ fontFamily: fonts.display, fontSize: "clamp(2.5rem, 5vw, 3.8rem)", fontWeight: 600, color: colors.white, lineHeight: 1.15, marginBottom: 0 }}>
