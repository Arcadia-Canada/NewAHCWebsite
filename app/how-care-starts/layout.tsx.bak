                  </div>
                  {/* Icon */}
                  <div style={{ flexShrink: 0, display: "flex", alignItems: "center", justifyContent: "center", width: 48, height: 48, background: "rgba(200,48,42,0.08)", borderRadius: 10, fontSize: 24 }}>
                    {icon}
                  </div>
                  {/* Content */}
                  <div style={{ flex: 1, minWidth: 0 }}>
                    <h3 style={{ fontFamily: fonts.display, fontSize: 19, fontWeight: 600, color: colors.primary, marginBottom: 8, lineHeight: 1.3 }}>
                      {title}
                    </h3>
                    <p style={{ fontSize: 15, color: colors.textLight, lineHeight: 1.65, marginBottom: 12 }}>
                      {description}
                    </p>
                    <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", paddingTop: 12, borderTop: `1px solid ${colors.border}` }}>
                      <span style={{ fontSize: 13, fontWeight: 700, color: colors.accent, textTransform: "uppercase", letterSpacing: "0.05em" }}>Learn More</span>
                      <span className="arc-card-arrow" style={{ fontSize: 18, color: colors.accent, transition: "all 0.2s" }}>→</span>
                    </div>
                  </div>
                </Link>
              </li>
            ))}
          </ul>
        </div>
      </section>

      {/* Bottom CTA */}
      <section style={{ background: colors.primary, padding: "80px 24px", textAlign: "center" }}>
