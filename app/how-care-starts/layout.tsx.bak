      </section>

      {/* Referral strip */}
      <section style={{ background: colors.warm, borderTop: `1px solid ${colors.border}`, padding: "56px 24px", display: "flex", justifyContent: "center" }}>
        <div style={{ maxWidth: 560, width: "100%", background: colors.surface, border: `1px solid ${colors.border}`, borderRadius: 12, padding: "28px 32px", textAlign: "center", boxShadow: "0 4px 16px rgba(28,43,58,0.06)" }}>
          <p style={{ fontSize: 11, fontWeight: 700, letterSpacing: "0.1em", textTransform: "uppercase", color: colors.textLight, marginBottom: 8 }}>
            For professionals
